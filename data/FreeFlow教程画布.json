    {
      "id": "tutorial-section-text-title",
      "type": "text",
      "text": "1. 文本可以直接写，也可以持续编辑",
      "html": "<div><strong>1. 文本可以直接写，也可以持续编辑</strong></div>",
      "plainText": "1. 文本可以直接写，也可以持续编辑",
      "title": "文本说明标题",
      "x": 120,
      "y": 350,
      "width": 540,
      "height": 52,
      "fontSize": 26,
      "color": "#0f172a",
      "locked": false,
