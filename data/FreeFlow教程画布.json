    {
      "id": "tutorial-section-file-title",
      "type": "text",
      "text": "3. 文件也能像卡片一样拖入管理",
      "html": "<div><strong>3. 文件也能像卡片一样拖入管理</strong></div>",
      "plainText": "3. 文件也能像卡片一样拖入管理",
